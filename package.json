{
  "name": "vaultcrdt-plugin",
  "version": "0.2.19",
  "description": "Obsidian plugin for VaultCRDT sync",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "bun esbuild.config.mjs",
